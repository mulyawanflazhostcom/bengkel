		{
			"name": "Customers",
			"description": "Endpoint untuk mendapatkan data pelanggan.",
			"item": [
				{
					"name": "Get All Customers",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"// Jika 401, langsung skip assertion data (token belum terisi)",
									"if (pm.response.code === 401) {",
									"    console.warn('⚠️ 401 Unauthenticated — pastikan Login sudah dijalankan atau token valid.');",
									"    return;",
									"}",
									"",
									"pm.test('Response format sukses', function () {",
									"    var json = pm.response.json();",
									"    pm.expect(json).to.have.property('success', true);",
									"    pm.expect(json).to.have.property('message', 'Daftar pelanggan.');",
									"    pm.expect(json).to.have.property('data');",
									"    pm.expect(json.data).to.be.an('array');",
									"});",
									"",
									"pm.test('Setiap pelanggan memiliki field yang sesuai', function () {",
									"    var json = pm.response.json();",
									"    if (json.data.length > 0) {",
									"        json.data.forEach(function(customer) {",
									"            pm.expect(customer).to.have.all.keys(",
									"                'id', 'name', 'phone', 'email', 'address',",
									"                'created_at', 'updated_at', 'vehicles_count', 'transactions_count'",
									"            );",
									"            pm.expect(customer.name).to.be.a('string');",
									"            pm.expect(customer.phone).to.match(/^\\d{10,15}$/);",
									"            pm.expect(customer.vehicles_count).to.be.a('number').that.is.at.least(0);",
									"            pm.expect(customer.transactions_count).to.be.a('number').that.is.at.least(0);",
									"        });",
									"        console.log('Jumlah pelanggan:', json.data.length);",
									"    } else {",
									"        console.log('Tidak ada data pelanggan (array kosong).');",
									"        pm.expect(json.data).to.be.empty;",
									"    }",
									"});",
									"",
									"pm.test('Data diurutkan berdasarkan nama (ascending)', function () {",
									"    var json = pm.response.json();",
									"    if (json.data.length > 1) {",
									"        for (var i = 1; i < json.data.length; i++) {",
									"            pm.expect(json.data[i].name.localeCompare(json.data[i-1].name)).to.be.at.least(0);",
									"        }",
									"    }",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/customers",
							"host": ["{{base_url}}"],
							"path": ["api", "customers"]
						},
